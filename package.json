{
  "name": "selene-agent",
  "version": "2.1.1",
  "description": "Selene AI Agent",
  "author": "Rahul Biju <rahulbiju@example.com>",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:backend": "pyinstaller selene-backend.spec --clean",
    "build": "electron-builder build --publish never",
    "publish": "electron-builder build --linux --win --mac --publish always"
  },
  "build": {
    "appId": "com.selene.agent",
    "productName": "Selene",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"]
    },
    "win": {
      "target": ["nsis"]
    },
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "extraFiles": [
      {
        "from": "dist",
        "to": "resources",
        "filter": [
          "selene-backend",
          "selene-backend.exe"
        ]
      }
    ]
  },
  "devDependencies": {
    "dmg-license": "^1.0.11",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}
